# Platform Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/schemasay

# JWT Security
SECRET_KEY=generate-a-strong-random-key-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# LLM Providers
OPENAI_API_KEY=your-openai-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here

# Fernet Encryption Key (for database credential storage)
# Generate this using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here
